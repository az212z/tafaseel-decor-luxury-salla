<style id="tafaseel-critical-style">
  :root {
    --tafaseel-night: #081115;
    --tafaseel-ink: #101820;
    --tafaseel-ink-soft: #24323a;
    --tafaseel-mist: #b8dce2;
    --tafaseel-mist-strong: #6fbfce;
    --tafaseel-ice: #eaf6f8;
    --tafaseel-silver: #f5f8f8;
    --tafaseel-pearl: #fbfcfc;
    --tafaseel-line: rgba(16, 24, 32, 0.12);
    --tafaseel-clay: #a8745f;
    --tafaseel-shadow: 0 24px 70px rgba(16, 24, 32, 0.12);
  }

  .theme-tafaseel-luxury {
    background: var(--tafaseel-silver);
    color: var(--tafaseel-ink);
  }

  .theme-tafaseel-luxury .container {
    max-width: 1240px;
  }

  .theme-tafaseel-luxury .store-header {
    position: relative;
    z-index: 20;
  }

  .theme-tafaseel-luxury .store-header .sr-only,
  .theme-tafaseel-luxury .store-header .navbar-brand h1,
  .theme-tafaseel-luxury .store-header .navbar-brand h2 {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    margin: -1px !important;
    padding: 0 !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    border: 0 !important;
    white-space: nowrap !important;
  }

  .theme-tafaseel-luxury .store-header .flex {
    display: flex;
  }

  .theme-tafaseel-luxury .store-header .flex-1 {
    flex: 1 1 0%;
    min-width: 0;
  }

  .theme-tafaseel-luxury .store-header .items-center {
    align-items: center;
  }

  .theme-tafaseel-luxury .store-header .items-stretch {
    align-items: stretch;
  }

  .theme-tafaseel-luxury .store-header .justify-between {
    justify-content: space-between;
  }

  .theme-tafaseel-luxury .store-header .justify-end {
    justify-content: flex-end;
  }

  .theme-tafaseel-luxury .store-header .relative {
    position: relative;
  }

  .theme-tafaseel-luxury .store-header .w-full {
    width: 100%;
  }

  .theme-tafaseel-luxury .store-header .my-2\.5 {
    margin-block: 0.625rem;
  }

  .theme-tafaseel-luxury .store-header a {
    text-decoration: none !important;
  }

  .theme-tafaseel-luxury .navbar-brand img {
    max-height: 58px;
    object-fit: contain;
  }

  .theme-tafaseel-luxury .top-navbar {
    background: var(--tafaseel-night);
    color: rgba(255, 255, 255, 0.78);
  }

  .theme-tafaseel-luxury .top-navbar .container {
    min-height: 42px;
    align-items: center;
    gap: 18px;
  }

  .theme-tafaseel-luxury .header-search {
    max-width: 460px;
    margin-inline: clamp(10px, 3vw, 36px);
  }

  .theme-tafaseel-luxury custom-main-menu > nav,
  .theme-tafaseel-luxury .main-menu {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 26px);
  }

  .theme-tafaseel-luxury custom-main-menu > nav ul,
  .theme-tafaseel-luxury .main-menu ul {
    display: flex;
    align-items: center;
    gap: clamp(14px, 2vw, 24px);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .theme-tafaseel-luxury custom-main-menu > nav li,
  .theme-tafaseel-luxury .main-menu li {
    display: flex;
    align-items: center;
  }

  .theme-tafaseel-luxury custom-main-menu > nav a,
  .theme-tafaseel-luxury .main-menu a {
    color: var(--tafaseel-ink) !important;
    font-size: 14px;
    font-weight: 700;
    text-decoration: none !important;
  }

  @media (min-width: 1024px) {
    .theme-tafaseel-luxury .store-header .lg\:hidden {
      display: none !important;
    }
  }

  .tafaseel-hero,
  .tafaseel-proof-row,
  .tafaseel-identity,
  .tafaseel-palette-finder,
  .tafaseel-categories,
  .tafaseel-curated-products,
  .tafaseel-live-products,
  .tafaseel-quality,
  .tafaseel-studio {
    box-sizing: border-box;
    font-family: inherit;
  }

  .tafaseel-hero {
    position: relative;
    min-height: clamp(620px, 78dvh, 820px);
    overflow: hidden;
    color: #fff;
    isolation: isolate;
    background: var(--tafaseel-night);
  }

  .tafaseel-hero__bg {
    position: absolute;
    inset: 0;
    z-index: -2;
    background-image: var(--tafaseel-hero-image);
    background-size: cover;
    background-position: center;
    transform: scale(1.04);
  }

  .tafaseel-hero__bg::after {
    position: absolute;
    inset: 0;
    content: "";
    background:
      linear-gradient(90deg, rgba(8, 17, 21, 0.94), rgba(16, 32, 38, 0.72) 44%, rgba(16, 32, 38, 0.26)),
      linear-gradient(0deg, rgba(8, 17, 21, 0.92), rgba(8, 17, 21, 0.08) 48%, rgba(8, 17, 21, 0.5));
  }

  [dir="ltr"] .tafaseel-hero__bg::after {
    background:
      linear-gradient(270deg, rgba(8, 17, 21, 0.94), rgba(16, 32, 38, 0.72) 44%, rgba(16, 32, 38, 0.26)),
      linear-gradient(0deg, rgba(8, 17, 21, 0.92), rgba(8, 17, 21, 0.08) 48%, rgba(8, 17, 21, 0.5));
  }

  .tafaseel-hero__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(360px, 0.72fr);
    align-items: center;
    gap: clamp(28px, 5vw, 72px);
    min-height: inherit;
    padding-block: clamp(58px, 8vw, 116px);
  }

  .tafaseel-hero__copy {
    max-width: 760px;
  }

  .tafaseel-hero__copy h1 {
    margin: 0;
    max-width: 12ch;
    color: #fff;
    font-size: clamp(48px, 8vw, 104px);
    font-weight: 900;
    line-height: 0.96;
    letter-spacing: 0;
  }

  .tafaseel-hero__copy p {
    max-width: 58ch;
    margin: 24px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.9;
  }

  .tafaseel-kicker {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
    color: var(--tafaseel-mist-strong);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .tafaseel-kicker::before {
    width: 34px;
    height: 1px;
    background: currentColor;
    content: "";
  }

  .tafaseel-kicker--light {
    color: rgba(184, 220, 226, 0.92);
  }

  .tafaseel-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 32px;
  }

  .tafaseel-btn {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-radius: 999px;
    padding: 0 24px;
    font-size: 15px;
    font-weight: 800;
    line-height: 1;
    text-decoration: none;
    transition: transform 180ms ease, border-color 220ms ease, background 220ms ease, color 220ms ease;
  }

  .tafaseel-btn:hover {
    transform: translateY(-2px);
  }

  .tafaseel-btn--primary {
    border: 1px solid transparent;
    background: var(--tafaseel-mist);
    color: var(--tafaseel-ink);
  }

  .tafaseel-btn--ghost {
    border: 1px solid rgba(255, 255, 255, 0.28);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .tafaseel-hero__gallery {
    position: relative;
    min-height: 560px;
  }

  .tafaseel-hero__frame {
    position: absolute;
    overflow: hidden;
    margin: 0;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 8px;
    box-shadow: 0 34px 88px rgba(0, 0, 0, 0.28);
    background: rgba(255, 255, 255, 0.06);
  }

  .tafaseel-hero__frame img,
  .tafaseel-category-card img,
  .tafaseel-product-card__image img,
  .tafaseel-studio__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tafaseel-hero__frame--main {
    inset: 0 8% 9% 0;
  }

  .tafaseel-hero__frame--float {
    right: auto;
    bottom: 0;
    left: 0;
    width: 46%;
    height: 42%;
  }

  .tafaseel-hero__frame--tall {
    top: 8%;
    right: 0;
    width: 32%;
    height: 58%;
  }

  .tafaseel-proof-row {
    position: relative;
    z-index: 5;
    margin-top: -42px;
  }

  .tafaseel-proof-row__inner {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.58);
    border-radius: 8px;
    background: rgba(251, 252, 252, 0.9);
    box-shadow: var(--tafaseel-shadow);
    backdrop-filter: blur(18px);
  }

  .tafaseel-proof-row__inner article {
    display: grid;
    gap: 8px;
    padding: clamp(16px, 2.2vw, 24px);
  }

  .tafaseel-proof-row__inner article + article {
    border-inline-start: 1px solid rgba(16, 24, 32, 0.1);
  }

  .tafaseel-proof-row__inner strong {
    color: var(--tafaseel-ink);
    font-size: 15px;
    font-weight: 900;
  }

  .tafaseel-proof-row__inner span {
    color: rgba(16, 24, 32, 0.6);
    font-size: 13px;
    font-weight: 700;
    line-height: 1.7;
  }

  .tafaseel-category-strip {
    position: relative;
    z-index: 4;
    margin-top: -34px;
  }

  .tafaseel-category-strip__inner {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.54);
    border-radius: 8px;
    padding: 14px;
    background: rgba(251, 252, 252, 0.88);
    box-shadow: var(--tafaseel-shadow);
    backdrop-filter: blur(18px);
  }

  .tafaseel-category-strip a,
  .tafaseel-link {
    color: var(--tafaseel-ink);
    font-weight: 900;
    text-decoration: none;
  }

  .tafaseel-category-strip a {
    border-radius: 999px;
    padding: 10px 16px;
    background: #fff;
  }

  .tafaseel-home-intro,
  .tafaseel-identity,
  .tafaseel-spaces,
  .tafaseel-palette-finder,
  .tafaseel-categories,
  .tafaseel-wall-sets,
  .tafaseel-curated-products,
  .tafaseel-advisor,
  .tafaseel-quality,
  .tafaseel-studio {
    padding-block: clamp(56px, 8vw, 96px);
  }

  .tafaseel-home-intro__inner,
  .tafaseel-identity__inner,
  .tafaseel-section-head--split,
  .tafaseel-studio__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
  }

  .tafaseel-home-intro h2,
  .tafaseel-identity h2,
  .tafaseel-section-head h2,
  .tafaseel-studio h2 {
    margin: 0;
    color: var(--tafaseel-ink);
    font-size: clamp(30px, 5vw, 58px);
    font-weight: 900;
    line-height: 1.08;
    letter-spacing: 0;
  }

  .tafaseel-home-intro p,
  .tafaseel-identity p,
  .tafaseel-category-card p,
  .tafaseel-product-card p,
  .tafaseel-studio p {
    color: rgba(16, 24, 32, 0.68);
    line-height: 1.9;
  }

  .tafaseel-identity__inner {
    align-items: center;
    border-radius: 8px;
    padding: clamp(28px, 5vw, 56px);
    background: linear-gradient(135deg, #fff, #eaf6f8);
    box-shadow: var(--tafaseel-shadow);
  }

  .tafaseel-identity__tokens {
    display: grid;
    grid-template-columns: repeat(2, 86px);
    gap: 12px;
  }

  .tafaseel-token {
    width: 86px;
    height: 86px;
    border-radius: 50%;
    border: 10px solid rgba(255, 255, 255, 0.82);
    box-shadow: 0 20px 40px rgba(16, 24, 32, 0.16);
  }

  .tafaseel-token--night { background: var(--tafaseel-night); }
  .tafaseel-token--mist { background: var(--tafaseel-mist); }
  .tafaseel-token--ice { background: var(--tafaseel-ice); }
  .tafaseel-token--clay { background: var(--tafaseel-clay); }

  .tafaseel-palette-finder__head {
    display: grid;
    gap: 12px;
    max-width: 720px;
    margin-bottom: clamp(20px, 3vw, 34px);
  }

  .tafaseel-palette-finder__head h2 {
    margin: 0;
    color: var(--tafaseel-ink);
    font-size: clamp(30px, 4.2vw, 54px);
    font-weight: 900;
    line-height: 1.08;
  }

  .tafaseel-palette-finder__head p {
    max-width: 58ch;
    margin: 0;
    color: rgba(16, 24, 32, 0.64);
    font-size: 16px;
    line-height: 1.85;
  }

  .tafaseel-palette-finder__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
  }

  .tafaseel-palette-card {
    display: grid;
    min-height: 250px;
    align-content: space-between;
    gap: 18px;
    overflow: hidden;
    border: 1px solid rgba(16, 24, 32, 0.1);
    border-radius: 8px;
    padding: 18px;
    background:
      radial-gradient(circle at 18% 14%, var(--palette-primary), transparent 38%),
      linear-gradient(135deg, var(--palette-secondary), #fff);
    color: var(--tafaseel-ink);
    box-shadow: 0 18px 48px rgba(16, 24, 32, 0.06);
    text-decoration: none;
  }

  .tafaseel-palette-card__swatches {
    display: flex;
    align-items: end;
    gap: 8px;
    min-height: 74px;
  }

  .tafaseel-palette-card__swatches i {
    display: block;
    width: 52px;
    border: 8px solid rgba(255, 255, 255, 0.72);
    border-radius: 999px;
    box-shadow: 0 16px 36px rgba(16, 24, 32, 0.12);
  }

  .tafaseel-palette-card__swatches i:nth-child(1) {
    height: 52px;
    background: var(--palette-primary);
  }

  .tafaseel-palette-card__swatches i:nth-child(2) {
    height: 66px;
    background: var(--palette-secondary);
  }

  .tafaseel-palette-card__swatches i:nth-child(3) {
    height: 44px;
    background: var(--palette-accent);
  }

  .tafaseel-palette-card strong {
    color: var(--tafaseel-ink);
    font-size: 22px;
    font-weight: 900;
  }

  .tafaseel-palette-card > span:not(.tafaseel-palette-card__swatches) {
    color: rgba(16, 24, 32, 0.64);
    font-size: 14px;
    font-weight: 700;
    line-height: 1.75;
  }

  .tafaseel-spaces__rail,
  .tafaseel-palette-finder__grid,
  .tafaseel-categories__grid,
  .tafaseel-wall-sets__grid,
  .tafaseel-products-grid,
  .tafaseel-quality__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .tafaseel-products-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .tafaseel-wall-sets__grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .tafaseel-space-card,
  .tafaseel-wall-set,
  .tafaseel-category-card,
  .tafaseel-product-card,
  .tafaseel-quality article,
  .tafaseel-live-products__frame {
    overflow: hidden;
    border: 1px solid var(--tafaseel-line);
    border-radius: 8px;
    background: var(--tafaseel-pearl);
    box-shadow: 0 18px 46px rgba(16, 24, 32, 0.08);
  }

  .tafaseel-space-card,
  .tafaseel-wall-set {
    display: grid;
    color: var(--tafaseel-ink);
    text-decoration: none;
  }

  .tafaseel-space-card__media,
  .tafaseel-wall-set__art {
    display: block;
    overflow: hidden;
    aspect-ratio: 1 / 0.72;
    background: var(--tafaseel-ice);
  }

  .tafaseel-space-card__media img,
  .tafaseel-wall-set__art img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .tafaseel-space-card__copy,
  .tafaseel-wall-set__copy {
    display: grid;
    gap: 9px;
    padding: 18px;
  }

  .tafaseel-space-card__copy small,
  .tafaseel-wall-set__copy small {
    color: var(--tafaseel-clay);
    font-size: 12px;
    font-weight: 900;
  }

  .tafaseel-space-card__copy strong,
  .tafaseel-wall-set__copy strong {
    color: var(--tafaseel-ink);
    font-size: 21px;
    font-weight: 900;
    line-height: 1.25;
  }

  .tafaseel-space-card__copy em,
  .tafaseel-space-card__copy span,
  .tafaseel-wall-set__copy span {
    color: rgba(16, 24, 32, 0.64);
    font-size: 13px;
    line-height: 1.7;
  }

  .tafaseel-space-card__copy em {
    font-style: normal;
    font-weight: 900;
  }

  .tafaseel-wall-set__art {
    position: relative;
    min-height: 290px;
    background:
      linear-gradient(90deg, rgba(16, 24, 32, 0.08) 1px, transparent 1px),
      linear-gradient(0deg, rgba(16, 24, 32, 0.08) 1px, transparent 1px),
      #eaf3f4;
    background-size: 34px 34px;
  }

  .tafaseel-wall-set__art-main,
  .tafaseel-wall-set__art-side {
    position: absolute;
    display: block;
    border: 10px solid #fff;
    border-radius: 4px;
    box-shadow: 0 22px 52px rgba(16, 24, 32, 0.18);
  }

  .tafaseel-wall-set__art-main {
    inset-inline-end: 14%;
    inset-block-start: 36px;
    width: 46%;
    aspect-ratio: 0.74;
  }

  .tafaseel-wall-set__art-side {
    inset-inline-start: 16%;
    inset-block-start: 78px;
    width: 34%;
    aspect-ratio: 0.78;
  }

  .tafaseel-category-card {
    position: relative;
    min-height: 380px;
    padding: 20px;
    color: #fff;
    text-decoration: none;
  }

  .tafaseel-category-card img {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .tafaseel-category-card::after {
    position: absolute;
    inset: 0;
    z-index: 1;
    content: "";
    background: linear-gradient(180deg, rgba(8, 17, 21, 0.08), rgba(8, 17, 21, 0.82));
  }

  .tafaseel-category-card span,
  .tafaseel-category-card h3,
  .tafaseel-category-card p,
  .tafaseel-category-card i {
    position: relative;
    z-index: 2;
  }

  .tafaseel-category-card h3,
  .tafaseel-product-card h3,
  .tafaseel-quality h3 {
    margin: 8px 0;
    font-size: 22px;
    font-weight: 900;
    line-height: 1.25;
  }

  .tafaseel-product-card__image {
    position: relative;
    display: block;
    aspect-ratio: 1 / 0.86;
    background: #eaf6f8;
  }

  .tafaseel-product-card__badge,
  .tafaseel-product-card__quick {
    position: absolute;
    z-index: 2;
  }

  .tafaseel-product-card__badge {
    inset-block-start: 14px;
    inset-inline-start: 14px;
    border-radius: 999px;
    padding: 7px 11px;
    color: var(--tafaseel-ink);
    font-size: 11px;
    font-weight: 900;
    background: rgba(255, 255, 255, 0.86);
  }

  .tafaseel-product-card__quick {
    inset-inline: 14px;
    inset-block-end: 14px;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .tafaseel-product-card__quick small,
  .tafaseel-product-card__meta small {
    border-radius: 999px;
    padding: 7px 10px;
    font-size: 11px;
    font-weight: 900;
  }

  .tafaseel-product-card__quick small {
    color: #fff;
    background: rgba(8, 17, 21, 0.74);
  }

  .tafaseel-product-card__body,
  .tafaseel-quality article {
    padding: 20px;
  }

  .tafaseel-product-card__body span {
    color: var(--tafaseel-clay);
    font-size: 12px;
    font-weight: 900;
  }

  .tafaseel-product-card__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 14px;
  }

  .tafaseel-product-card__meta small {
    color: rgba(16, 24, 32, 0.62);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--tafaseel-line);
  }

  .tafaseel-product-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-top: 18px;
    border-top: 1px solid var(--tafaseel-line);
    padding-top: 16px;
  }

  .tafaseel-product-card__footer a {
    color: var(--tafaseel-ink);
    font-weight: 900;
    text-decoration: none;
  }

  .tafaseel-advisor__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(300px, 0.88fr) auto;
    gap: clamp(20px, 4vw, 48px);
    align-items: end;
    border-radius: 8px;
    padding: clamp(24px, 5vw, 48px);
    background: var(--tafaseel-night);
    box-shadow: var(--tafaseel-shadow);
  }

