<section class="tafaseel-identity" aria-labelledby="tafaseel-identity-title">
    <div class="container tafaseel-identity__inner">
        <div class="tafaseel-identity__copy" data-tafaseel-reveal>
            <span class="tafaseel-kicker">هوية تفاصيل الجديدة</span>
            <h2 id="tafaseel-identity-title">جدار هادئ، حضور واضح، ولمعة باردة تشبه المعارض الحديثة.</h2>
            <p>
                الهوية تجمع بين الأزرق الضبابي، الجرافيت العميق، والأبيض الحجري حتى تبدو
                المنتجات أكثر نقاء، وتبقى تجربة التسوق مناسبة للبيت، المكتب، والمحل.
            </p>
        </div>
        <div class="tafaseel-identity__tokens" aria-hidden="true" data-tafaseel-reveal>
            <span class="tafaseel-token tafaseel-token--night"></span>
            <span class="tafaseel-token tafaseel-token--mist"></span>
            <span class="tafaseel-token tafaseel-token--ice"></span>
            <span class="tafaseel-token tafaseel-token--clay"></span>
        </div>
    </div>
</section>

<section class="tafaseel-categories" aria-labelledby="tafaseel-categories-title">
    <div class="container">
        <div class="tafaseel-section-head" data-tafaseel-reveal>
            <span class="tafaseel-kicker">تسوق حسب أجواء المساحة</span>
            <h2 id="tafaseel-categories-title">كل مجموعة لها إحساسها، وكل جدار له اختيار مناسب.</h2>
        </div>
        <div class="tafaseel-categories__grid">
            {% for category in tafaseel_categories %}
                <a class="tafaseel-category-card tafaseel-motion-card" href="#{{ category.id }}" data-tafaseel-reveal>
                    <img src="{{ category.image }}" alt="{{ category.title }}" loading="lazy">
                    <span>{{ category.name }}</span>
                    <h3>{{ category.title }}</h3>
                    <p>{{ category.text }}</p>
                    <i class="sicon-keyboard_arrow_left" aria-hidden="true"></i>
                </a>
            {% endfor %}
        </div>
    </div>
</section>

<section class="tafaseel-curated-products" aria-labelledby="tafaseel-products-title">
    <div class="container">
        <div class="tafaseel-section-head tafaseel-section-head--split" data-tafaseel-reveal>
            <div>
                <span class="tafaseel-kicker">منتجات حقيقية من المتجر</span>
                <h2 id="tafaseel-products-title">مختارات واجهة فاخرة من تفاصيل الديكور.</h2>
            </div>
            <a class="tafaseel-link" href="https://wa.me/{{ tafaseel_whatsapp_clean }}" rel="noopener" target="_blank">
                مساعدة في اختيار المقاس
                <i class="sicon-keyboard_arrow_left" aria-hidden="true"></i>
            </a>
        </div>
        <div class="tafaseel-products-grid">
            {% for product in tafaseel_products %}
                <article id="{{ product.anchor }}" class="tafaseel-product-card" data-tafaseel-reveal>
                    <a class="tafaseel-product-card__image" href="{{ product.url }}" aria-label="{{ product.title }}">
                        <img src="{{ product.image }}" alt="{{ product.title }}" loading="lazy">
                    </a>
                    <div class="tafaseel-product-card__body">
                        <span>{{ product.category }}</span>
                        <h3>{{ product.title }}</h3>
                        <p>{{ product.subtitle }}</p>
                        <div class="tafaseel-product-card__footer">
                            <strong>السعر حسب المقاس</strong>
                            <a href="{{ product.url }}">
                                عرض التفاصيل
                                <i class="sicon-keyboard_arrow_left" aria-hidden="true"></i>
                            </a>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    </div>
</section>

<section class="tafaseel-live-products container" aria-label="منتجات مختارة من سلة" data-tafaseel-reveal>
    <div class="tafaseel-live-products__frame">
        <salla-products-slider
            source="selected"
            source-value="[196185830,95892278,2027503937,1105613328,1168091433,1242572484,1723490227,280435721]"
            block-title="تسوق المختارات مباشرة من سلة"
            block-subTitle="الأسعار والمخزون والخيارات تأتي من كتالوج المتجر."
            slider-id="tafaseel-real-store-products"
        ></salla-products-slider>
    </div>
</section>
