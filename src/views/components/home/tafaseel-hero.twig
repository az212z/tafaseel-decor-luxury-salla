{% set tafaseel_whatsapp = store.contacts.whatsapp ?? store.contacts.mobile ?? '966558113005' %}
{% set tafaseel_whatsapp_clean = tafaseel_whatsapp|replace({'+':'', ' ':'', '-':'', '(':'', ')':''}) %}
{% set tafaseel_component = component is defined ? component : null %}
{% set tafaseel_title = tafaseel_component and tafaseel_component.hero_title ? tafaseel_component.hero_title : 'تفاصيل الديكور' %}
{% set tafaseel_description = tafaseel_component and tafaseel_component.hero_description ? tafaseel_component.hero_description : 'لوحات جدارية وورق حائط بتفاصيل هادئة، خامات كانفس مقاومة، وضمان ألوان 3 سنوات.' %}
{% set tafaseel_hero_image = tafaseel_component and tafaseel_component.hero_image ? tafaseel_component.hero_image : 'https://cdn.salla.sa/gZrqEE/64cc7fb0-ccb1-4bb8-ac2f-1e63e8c4fa02-500x500-XS6J6gCt8vtJgt9IC71ad2MpO5WatzVPSMOFxew8.jpg' %}
{% set tafaseel_accent_image = tafaseel_component and tafaseel_component.accent_image ? tafaseel_component.accent_image : 'https://cdn.salla.sa/gZrqEE/1e65f02a-7119-431f-ac15-e00fa4d08908-500x498.86363636364-7BWHNVo87rNG36T7ZrR5G2HApHnOWeo6pxbgpt0N.jpg' %}
{% set tafaseel_tall_image = tafaseel_component and tafaseel_component.tall_image ? tafaseel_component.tall_image : 'https://cdn.salla.sa/gZrqEE/07b2e16f-9186-4ced-9e8d-0eacefb7a064-500x500-vOgwn6Waw6Cg3TPst7qbWkhMdBLi1HS4R1gSRHRk.jpg' %}
{% set tafaseel_primary_label = tafaseel_component and tafaseel_component.primary_label ? tafaseel_component.primary_label : 'تسوق المجموعة' %}
{% set tafaseel_secondary_label = tafaseel_component and tafaseel_component.secondary_label ? tafaseel_component.secondary_label : 'استشارة مقاس' %}

<section class="tafaseel-hero" style="--tafaseel-hero-image: url('{{ tafaseel_hero_image }}')">
    <div class="tafaseel-hero__bg" aria-hidden="true"></div>
    <div class="container tafaseel-hero__inner">
        <div class="tafaseel-hero__copy" data-tafaseel-reveal>
            <span class="tafaseel-kicker tafaseel-kicker--light">Decoration Details</span>
            <h1>{{ tafaseel_title }}</h1>
            <p>{{ tafaseel_description }}</p>
            <div class="tafaseel-hero__actions">
                <a class="tafaseel-btn tafaseel-btn--primary" href="#tafaseel-collection">
                    <span>{{ tafaseel_primary_label }}</span>
                    <i class="sicon-keyboard_arrow_left" aria-hidden="true"></i>
                </a>
                <a class="tafaseel-btn tafaseel-btn--ghost" href="https://wa.me/{{ tafaseel_whatsapp_clean }}" rel="noopener" target="_blank">
                    <span>{{ tafaseel_secondary_label }}</span>
                </a>
            </div>
            <div class="tafaseel-hero__proof" aria-label="مزايا تفاصيل الديكور">
                <span>كانفس مقاوم للرطوبة</span>
                <span>ضمان ألوان 3 سنوات</span>
                <span>مقاسات متعددة</span>
            </div>
        </div>

        <div class="tafaseel-hero__gallery" data-tafaseel-reveal>
            <figure class="tafaseel-hero__frame tafaseel-hero__frame--main">
                <img src="{{ tafaseel_hero_image }}" alt="لوحة جدارية فاخرة من تفاصيل الديكور" loading="eager" fetchpriority="high">
            </figure>
            <figure class="tafaseel-hero__frame tafaseel-hero__frame--float tafaseel-motion-card">
                <img src="{{ tafaseel_accent_image }}" alt="لوحة ورد بتدرجات هادئة" loading="lazy">
            </figure>
            <figure class="tafaseel-hero__frame tafaseel-hero__frame--tall tafaseel-motion-card">
                <img src="{{ tafaseel_tall_image }}" alt="لوحة خيول بتكوين عصري" loading="lazy">
            </figure>
        </div>
    </div>
</section>

<section class="tafaseel-category-strip" aria-label="تصنيفات تفاصيل الديكور" data-tafaseel-reveal>
    <div class="container tafaseel-category-strip__inner">
        <a href="#tafaseel-floral">الورد</a>
        <a href="#tafaseel-abstract">تجريدي</a>
        <a href="#tafaseel-horses">خيول</a>
        <a href="#tafaseel-wallpaper">ورق الحائط</a>
        <a href="#tafaseel-large">لوحات حجم كبير</a>
    </div>
</section>

<section id="tafaseel-collection" class="tafaseel-home-intro">
    <div class="container tafaseel-home-intro__inner" data-tafaseel-reveal>
        <div>
            <h2>اختيارات مصممة لتظهر في المساحة، لا لتملأها فقط.</h2>
            <p>
                مجموعة مختارة للصالات، المداخل، غرف النوم، والمكاتب؛ بألوان هادئة
                وحضور بصري يعطي الجدار قيمة من غير ازدحام.
            </p>
        </div>
        <a class="tafaseel-link" href="https://wa.me/{{ tafaseel_whatsapp_clean }}" rel="noopener" target="_blank">
            اطلب تنسيق خاص للمقاس
            <i class="sicon-keyboard_arrow_left" aria-hidden="true"></i>
        </a>
    </div>
</section>
